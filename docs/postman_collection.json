{
  "info": {
    "_postman_id": "8f4b7138-7c2a-4d48-b6cc-audio-chatterbox",
    "name": "Evo Chatterbox Local",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for testing the Evo Chatterbox local API."
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000"
    },
    {
      "key": "sample_text_en",
      "value": "Hello, this is a test generated by Evo Chatterbox."
    },
    {
      "key": "sample_text_pt",
      "value": "Ola, este e um teste gerado pelo Evo Chatterbox."
    },
    {
      "key": "reference_audio_path",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/health",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "health"
          ]
        },
        "description": "Check if the API is running."
      }
    },
    {
      "name": "Config",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/config",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "config"
          ]
        },
        "description": "Returns active device and supported languages."
      }
    },
    {
      "name": "Generate EN",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "text",
              "value": "{{sample_text_en}}",
              "type": "text"
            },
            {
              "key": "language_id",
              "value": "en",
              "type": "text"
            },
            {
              "key": "exaggeration",
              "value": "0.5",
              "type": "text"
            },
            {
              "key": "cfg_weight",
              "value": "0.5",
              "type": "text"
            },
            {
              "key": "temperature",
              "value": "0.8",
              "type": "text"
            }
          ]
        },
        "url": {
          "raw": "{{base_url}}/generate",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "generate"
          ]
        },
        "description": "Generate audio in English using the standard backend."
      }
    },
    {
      "name": "Generate PT",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "text",
              "value": "{{sample_text_pt}}",
              "type": "text"
            },
            {
              "key": "language_id",
              "value": "pt",
              "type": "text"
            },
            {
              "key": "exaggeration",
              "value": "0.5",
              "type": "text"
            },
            {
              "key": "cfg_weight",
              "value": "0.5",
              "type": "text"
            },
            {
              "key": "temperature",
              "value": "0.8",
              "type": "text"
            }
          ]
        },
        "url": {
          "raw": "{{base_url}}/generate",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "generate"
          ]
        },
        "description": "Generate audio in Portuguese using the multilingual backend."
      }
    },
    {
      "name": "Generate With Voice Prompt",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "text",
              "value": "{{sample_text_pt}}",
              "type": "text"
            },
            {
              "key": "language_id",
              "value": "pt",
              "type": "text"
            },
            {
              "key": "exaggeration",
              "value": "0.35",
              "type": "text"
            },
            {
              "key": "cfg_weight",
              "value": "0.55",
              "type": "text"
            },
            {
              "key": "temperature",
              "value": "0.75",
              "type": "text"
            },
            {
              "key": "audio_prompt",
              "type": "file",
              "src": "{{reference_audio_path}}"
            }
          ]
        },
        "url": {
          "raw": "{{base_url}}/generate",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "generate"
          ]
        },
        "description": "Generate audio using a voice reference file. Set the reference_audio_path variable in Postman."
      }
    }
  ]
}

